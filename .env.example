# =============================================================================
# ACME Banking Security Testbed — Master Environment Configuration
# =============================================================================
# HOW TO SWITCH MODES:
#
#   MODE A — Local Splunk (default, Splunk runs as a container):
#     1. Set SPLUNK_MODE=local  (already set below)
#     2. Run: docker compose --profile local up --build -d
#     3. Run: ./scripts/splunk_local_bootstrap.sh  (HEC + index — not automatic)
#
#   MODE B — External Splunk Cloud or Enterprise:
#     1. Set SPLUNK_MODE=external
#     2. Fill in SPLUNK_HEC_ENDPOINT, SPLUNK_HEC_TOKEN, SPLUNK_HEC_INDEX below
#     3. Run: docker compose -f docker-compose.yml -f docker-compose.external.yml up --build -d
#
#   MODE C — Cloud VM (AWS EC2 / Azure / GCP):
#     Same as A or B on the VM; open firewall ports 5000, 5001, (8000 if local Splunk)
#     only to your VPN — see docs/CLOUD_VM_DEPLOYMENT.md
#
# =============================================================================

# -----------------------------------------------------------------------------
# SPLUNK MODE SELECTOR
# Values: local | external
# -----------------------------------------------------------------------------
SPLUNK_MODE=local

# =============================================================================
# SECTION A — LOCAL SPLUNK SETTINGS
# Only used when SPLUNK_MODE=local
# These configure the Splunk container that Docker Compose spins up locally.
# =============================================================================

# Admin password for the local Splunk container Web UI (http://localhost:8000)
SPLUNK_PASSWORD=ACMEPassword2026!

# Default HEC token value (must match SPLUNK_HEC_TOKEN below).
# Local Docker Splunk does NOT create this token on boot — run:
#   ./scripts/splunk_local_bootstrap.sh
SPLUNK_LOCAL_HEC_TOKEN=acme-hec-token-0000-1111-2222-3333

# Local Splunk image version
SPLUNK_IMAGE=splunk/splunk:9.2.1

# =============================================================================
# SECTION B — SHARED HEC EXPORT SETTINGS
# These apply to BOTH local and external modes.
# In local mode: point at the local container (defaults below are correct).
# In external mode: replace with your Splunk Cloud / Enterprise values.
# =============================================================================

# --- For LOCAL mode, leave these as-is ---
SPLUNK_HEC_ENDPOINT=http://splunk:8088/services/collector/event
SPLUNK_HEC_TOKEN=acme-hec-token-0000-1111-2222-3333
SPLUNK_HEC_INDEX=acme_agentic_telemetry
SPLUNK_HEC_SOURCETYPE=otel:agentic:json
SPLUNK_HEC_SOURCE=otel-collector-mesh

# TLS verification:
#   local mode  → true  (skip verification, self-signed cert on container)
#   external    → false (Splunk Cloud uses valid CA-signed certificates)
SPLUNK_HEC_TLS_SKIP_VERIFY=true

# --- For EXTERNAL Splunk Cloud, replace the block above with: ---
#
# SPLUNK_MODE=external
# SPLUNK_HEC_ENDPOINT=https://http-inputs-<YOUR_STACK>.splunkcloud.com/services/collector/event
# SPLUNK_HEC_TOKEN=<YOUR_SPLUNK_CLOUD_HEC_TOKEN>
# SPLUNK_HEC_INDEX=acme_agentic_telemetry
# SPLUNK_HEC_SOURCETYPE=otel:agentic:json
# SPLUNK_HEC_SOURCE=otel-collector-mesh
# SPLUNK_HEC_TLS_SKIP_VERIFY=false
#
# Then install the Splunk app on Splunk Cloud:
#   ./scripts/package_splunk_app.sh
#   Upload dist/acme_genai_compliance-2.0.0.tar.gz via Apps → Upload app
#   See splunk_app/INSTALL.md for full steps
#
# --- For EXTERNAL Splunk Enterprise (on-prem/VM), replace with: ---
#
# SPLUNK_HEC_ENDPOINT=https://<YOUR_SPLUNK_HOST>:8088/services/collector/event
# SPLUNK_HEC_TOKEN=<YOUR_HEC_TOKEN>
# SPLUNK_HEC_INDEX=acme_agentic_telemetry
# SPLUNK_HEC_SOURCETYPE=otel:agentic:json
# SPLUNK_HEC_SOURCE=otel-collector-mesh
# SPLUNK_HEC_TLS_SKIP_VERIFY=false

# =============================================================================
# SECTION C — OTEL COLLECTOR SETTINGS
# =============================================================================

OTEL_COLLECTOR_IMAGE=otel/opentelemetry-collector-contrib:0.96.0

# Batch processor tuning
OTEL_BATCH_SIZE=512
OTEL_BATCH_TIMEOUT=2s
OTEL_BATCH_MAX_SIZE=1024

# Memory limiter
OTEL_MEMORY_LIMIT_MIB=512
OTEL_MEMORY_SPIKE_MIB=128

# =============================================================================
# SECTION D — APPLICATION SETTINGS
# =============================================================================

# Banking app OTel targets (always point at the OTel Collector container)
OTEL_COLLECTOR_HTTP=http://otel_collector:4318
OTEL_COLLECTOR_GRPC=otel_collector:4317

OTEL_SERVICE_NAME=acme-banking-fabric
OTEL_SERVICE_VERSION=1.0.0
ACME_ENV=production

# Attack panel target
BANKING_APP_URL=http://banking_app:5000

# -----------------------------------------------------------------------------
# OLLAMA — single model for entire lab (not auto-selected per agent)
# -----------------------------------------------------------------------------
OLLAMA_MODEL=llama3.2:1b

# Ollama container: seconds to wait for API ready on first boot (increase on small VMs)
OLLAMA_STARTUP_WAIT_SEC=300

# -----------------------------------------------------------------------------
# RUNTIME CONTROLS — lab middleware in apps/agents/llm_client.py
# Set to false only for debugging / baseline comparisons
# -----------------------------------------------------------------------------
DEFENSECLAW_ENABLED=true
CODEGUARD_ENABLED=true

# -----------------------------------------------------------------------------
# CISCO AI DEFENSE + MLTK (optional — use docker-compose.cisco.yml overlay)
# https://github.com/cisco-ai-defense | docs/CISCO_INTEGRATION.md
# -----------------------------------------------------------------------------
LAB_MODE=teach
CISCO_INTEGRATION_ENABLED=true
FOUNDATION_SEC_ENABLED=true
FOUNDATION_SEC_PULL=false
OLLAMA_SECURITY_MODEL=hf.co/fdtn-ai/Foundation-Sec-8B-GGUF:Q4_K_M

# -----------------------------------------------------------------------------
# CONTINUOUS BASELINE TRAFFIC — benign loan requests → Splunk between attacks
# Emits testbed_mode=BASELINE_TRAFFIC on otel:agentic:json (filter in hunts)
# -----------------------------------------------------------------------------
TRAFFIC_SIM_ENABLED=true
TRAFFIC_SIM_INTERVAL_MIN_SEC=90
TRAFFIC_SIM_INTERVAL_MAX_SEC=240
TRAFFIC_SIM_PIPELINE_RATIO=0.2
TRAFFIC_SIM_STARTUP_DELAY_SEC=45
TRAFFIC_SIM_WAIT_FOR_OLLAMA=true

# -----------------------------------------------------------------------------
# CSA MAESTRO WORKSHOP (optional — external Node app, not in Docker Compose)
# https://github.com/CloudSecurityAlliance/MAESTRO | docs/MAESTRO_WORKSHOP.md
# -----------------------------------------------------------------------------
MAESTRO_UI_URL=http://localhost:9002
