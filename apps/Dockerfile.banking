# =============================================================================
# OrchestraACME — Banking App Container v3
# Build context: repository root
# =============================================================================
FROM python:3.11-slim

LABEL maintainer="OrchestraACME"
LABEL description="ACME Banking Multi-Agent Fabric — Real Ollama LLM loop"

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends curl \
    && rm -rf /var/lib/apt/lists/*

COPY apps/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY apps/app_runtime.py .
COPY apps/agents/ ./agents/
COPY apps/framework/ ./framework/
COPY data/ ./data/

RUN mkdir -p /var/log/defenseclaw

EXPOSE 5000
CMD ["python", "app_runtime.py"]
